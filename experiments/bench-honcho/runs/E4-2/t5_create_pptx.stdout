+const pptxgen = require("pptxgenjs");
+
+let pres = new pptxgen();
+pres.layout = "LAYOUT_WIDE";
+pres.author = "Yuki";
+pres.title = "New Opportunities for Local LLMs";
+
+// ======================================================
+// COLOR PALETTE
+// ======================================================
+const C = {
+  navy:     "0B1120",
+  teal:     "06A77D",
+  cyan:     "22D3EE",
+  white:    "FFFFFF",
+  offWhite: "F1F5F9",
+  lightGray:"E2E8F0",
+  darkGray: "334155",
+  midGray:  "64748B",
+  black:    "020617",
+  cardBg:   "FFFFFF",
+  accentBlue:"3B82F6",
+  mutedBg1:  "0F172A",
+  mutedBg2:  "1E293B",
+  gold:     "F59E0B",
+};
+
+// ======================================================
+// SLIDE 1 - TITLE SLIDE
+// ======================================================
+const s1 = pres.addSlide();
+s1.background = { color: C.navy };
+
+// Subtle geometric accent lines
+s1.addShape(pres.shapes.RECTANGLE, { x: 0, y: 0, w: 13.3, h: 0.06, fill: { color: C.teal } });
+s1.addShape(pres.shapes.RECTANGLE, { x: 0, y: 5.58, w: 13.3, h: 0.06, fill: { color: C.teal } });
+
+// Large accent box behind title
+s1.addShape(pres.shapes.RECTANGLE, {
+  x: 1.0, y: 1.4, w: 11.3, h: 2.2,
+  fill: { color: C.teal, transparency: 0.88 }
+});
+
+// Title text
+s1.addText("New Opportunities\nfor Local LLMs", {
+  x: 1.0, y: 1.6, w: 11.3, h: 1.8,
+  fontSize: 42, fontFace: "Calibri",
+  color: C.white, bold: true,
+  align: "center", valign: "middle"
+});
+
+// Subtitle
+s1.addText("Hybrid Deployment, Edge Inference, and the Shift from\nAPI Dependency to On-Prem Control", {
+  x: 1.5, y: 3.7, w: 10.3, h: 0.7,
+  fontSize: 18, fontFace: "Calibri",
+  color: C.lightGray,
+  align: "center"
+});
+
+// Bottom accent tagline
+s1.addShape(pres.shapes.RECTANGLE, {
+  x: 5.65, y: 4.7, w: 2.0, h: 0.04,
+  fill: { color: C.cyan }
+});
+
+s1.addText("MARKET TRENDS  HYBRID ARCHITECTURE  STRATEGIC ROADMAP", {
+  x: 2.0, y: 5.0, w: 9.3, h: 0.4,
+  fontSize: 11, fontFace: "Calibri",
+  color: C.teal, bold: true,
+  align: "center", charSpacing: 3
+});
+
+//
